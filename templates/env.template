# nanobot-companion environment configuration
# Generated by setup.sh — do not commit this file.
# All bash scripts source this for paths and identifiers.
#
# IMPORTANT: API keys do NOT go here — this file is readable by the agent.
# API keys go in docker-compose.override.yml (see docs/architecture.md).

# Workspace root (Nanobot default: ~/.nanobot/workspace)
WORKSPACE="__WORKSPACE__"

# Derived paths — change WORKSPACE and these follow
MEMORY_DIR="${WORKSPACE}/memory"
SKILLS_DIR="${WORKSPACE}/skills"
DATA_DIR="${WORKSPACE}/skills-data"

# Timezone (IANA format, used for all date operations)
TZ="__TIMEZONE__"

# Identity
AGENT_NAME="__AGENT_NAME__"
USER_NAME="__USER_NAME__"

# ---------------------------------------------------------------------------
# Image generation (optional — leave empty if not configured)
# Used by: weekly-state-of-me (visual journal), dreaming (dream images)
# See docs/image-generation-interface.md for the full contract.
# ---------------------------------------------------------------------------

# Text-to-image: must accept --prompt "..." --output /path/to/file.webp
IMAGE_GEN_CMD=""
# Examples:
# IMAGE_GEN_CMD="python3 ${SKILLS_DIR}/venice-ai-media/scripts/venice-image.py"
# IMAGE_GEN_CMD="python3 ${SKILLS_DIR}/openrouter-image-simple/scripts/generate.py"

# Reference-based image editing (character consistency in dream images)
# Must accept --input reference.webp --prompt "..." --output /path/to/file.webp
IMAGE_EDIT_CMD=""
# Example:
# IMAGE_EDIT_CMD="python3 ${SKILLS_DIR}/venice-ai-media/scripts/venice-edit.py"

# Companion reference images for character-consistent selfie/dream images
# Portrait ref used for close-ups; body ref for scene/candid modes.
# See docs/image-generation-interface.md for tips on creating good references.
COMPANION_REFERENCE_PORTRAIT=""
COMPANION_REFERENCE_BODY=""
# Examples:
# COMPANION_REFERENCE_PORTRAIT="${WORKSPACE}/identity/reference-portrait.webp"
# COMPANION_REFERENCE_BODY="${WORKSPACE}/identity/reference-body.webp"

# ---------------------------------------------------------------------------
# Blog writer (optional — 0 disables auto-proposals)
# How often (in days) to check for accumulated material worth writing about.
# The cron runs daily but only proposes if enough days have passed.
# ---------------------------------------------------------------------------
BLOG_CHECK_DAYS=0

# ---------------------------------------------------------------------------
# Dreaming — all config is in skills-data/dreaming/dream-config.json
# No .env variables needed. Models, topics, styles, and timing are
# configured there. See skills/dreaming/SKILL.md for details.
# ---------------------------------------------------------------------------
