# openclaw-companion .gitignore
# The repo IS the workspace. This file defines the split:
#   Git-tracked:  skills/, templates/, docs/, lib/, setup.sh, README.md
#   Gitignored:   everything generated, accumulated, or user-specific

# Instance data — never committed to the framework repo
memory/*
!memory/.gitkeep
SOUL.md
USER.md
IDENTITY.md
MEMORY.md
TOOLS.md
AGENTS.md
location.json
.env

# Runtime skill data — created by wizard, never touched by git
skills-data/

# Credentials
*.env.local
**/secrets/

# OS
.DS_Store
Thumbs.db
.claude/.mcp.local.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
